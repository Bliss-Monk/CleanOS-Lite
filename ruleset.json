{
  "_comment": "CleanOS Lite Ruleset — update this file to push new telemetry coverage to all installations.",
  "_comment2": "Bump 'version' on every change. Sentry compares this against its cached copy on each login.",
  "version": "2026.03.31",

  "registry": [
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
      "name": "AllowTelemetry", "value": 0, "type": "DWORD",
      "note": "Lock telemetry — Home/Pro fallback keys below handle enforcement" },
    { "path": "HKLM:\\SOFTWARE\\CurrentControlSet\\Control\\WMI\\Autologger\\AutoLogger-Diagtrack-Listener",
      "name": "Start", "value": 0, "type": "DWORD",
      "note": "Kill DiagTrack autologger at boot" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
      "name": "LimitDiagnosticLogCollection", "value": 1, "type": "DWORD",
      "note": "Home/Pro fallback — cuts off pipeline regardless of edition" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
      "name": "DisableOneSettingsDownloads", "value": 1, "type": "DWORD",
      "note": "Prevent MS pushing new data-collection configs post-update" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
      "name": "DoNotShowFeedbackNotifications", "value": 1, "type": "DWORD",
      "note": "Suppress feedback popups" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DataCollection",
      "name": "DisableDiagnosticDataViewer", "value": 1, "type": "DWORD",
      "note": "Block access to the telemetry data viewer" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Recall",
      "name": "DisableRecall", "value": 1, "type": "DWORD",
      "note": "Disable AI Recall screenshot feature" },
    { "path": "HKCU:\\Software\\Policies\\Microsoft\\Windows\\WindowsAI",
      "name": "DisableAIDataAnalysis", "value": 1, "type": "DWORD",
      "note": "Disable AI data analysis pipeline" },
    { "path": "HKCU:\\Software\\Policies\\Microsoft\\Windows\\WindowsCopilot",
      "name": "TurnOffWindowsCopilot", "value": 1, "type": "DWORD",
      "note": "Block Copilot" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Windows Search",
      "name": "AllowCortana", "value": 0, "type": "DWORD",
      "note": "Block Cortana backend" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\System",
      "name": "EnableActivityFeed", "value": 0, "type": "DWORD",
      "note": "Stop Windows logging what the user opens" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\System",
      "name": "PublishUserActivities", "value": 0, "type": "DWORD",
      "note": "Stop activity being published to MS account" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\System",
      "name": "UploadUserActivities", "value": 0, "type": "DWORD",
      "note": "Stop activity history being uploaded" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\DeliveryOptimization",
      "name": "DODownloadMode", "value": 0, "type": "DWORD",
      "note": "Disable P2P update sharing via user bandwidth" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\Windows Error Reporting",
      "name": "Disabled", "value": 1, "type": "DWORD",
      "note": "Stop crash dumps being sent to Microsoft" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\CloudContent",
      "name": "DisableWindowsConsumerFeatures", "value": 1, "type": "DWORD",
      "note": "Stop MS silently installing suggested apps" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\CloudContent",
      "name": "DisableCloudOptimizedContent", "value": 1, "type": "DWORD",
      "note": "Block cloud-pushed Spotlight ads and tips" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\NetworkConnectivityStatusIndicator",
      "name": "NoActiveProbe", "value": 1, "type": "DWORD",
      "note": "Disable NCSI phone-home probe" },
    { "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
      "name": "RotatingLockScreenEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Spotlight lock screen" },
    { "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\ContentDeliveryManager",
      "name": "SubscribedContent-338388Enabled", "value": 0, "type": "DWORD",
      "note": "Disable Windows tips and suggestions" },
    { "path": "HKLM:\\SYSTEM\\CurrentControlSet\\Control\\Session Manager\\Power",
      "name": "HiberbootEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Fast Startup for clean shutdown behaviour" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers",
      "name": "DisableHTTPPrinting", "value": 1, "type": "DWORD",
      "note": "Disable print spooler HTTP telemetry" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows NT\\Printers",
      "name": "DisableWebPnPDownload", "value": 1, "type": "DWORD",
      "note": "Disable web printer driver downloads" },
    { "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Privacy",
      "name": "TailoredExperiencesWithDiagnosticDataEnabled", "value": 0, "type": "DWORD",
      "note": "Disable tailored experiences" },
    { "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\AdvertisingInfo",
      "name": "Enabled", "value": 0, "type": "DWORD",
      "note": "Disable Advertising ID" },
    { "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\Search",
      "name": "BingSearchEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Bing in Start Menu" },
    { "path": "HKCU:\\Software\\Microsoft\\Windows\\CurrentVersion\\SearchSettings",
      "name": "IsDynamicSearchBoxEnabled", "value": 0, "type": "DWORD",
      "note": "Disable taskbar search highlights" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
      "name": "MetricsReportingEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Edge usage stats" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
      "name": "PersonalizationReportingEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Edge personalisation data" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
      "name": "UserFeedbackAllowed", "value": 0, "type": "DWORD",
      "note": "Disable Edge feedback" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
      "name": "StartupBoostEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Edge startup boost" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Edge",
      "name": "BackgroundModeEnabled", "value": 0, "type": "DWORD",
      "note": "Disable Edge background mode" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsUpdate\\AU",
      "name": "AUOptions", "value": 2, "type": "DWORD",
      "note": "Notify before download — user controls feature update install" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsUpdate",
      "name": "DeferFeatureUpdates", "value": 1, "type": "DWORD",
      "note": "Defer feature updates 30 days" },
    { "path": "HKLM:\\SOFTWARE\\Policies\\Microsoft\\Windows\\WindowsUpdate",
      "name": "DeferFeatureUpdatesPeriodInDays", "value": 30, "type": "DWORD",
      "note": "30-day deferral window" }
  ],

  "hosts": [
    "vortex.data.microsoft.com",
    "v10.events.data.microsoft.com",
    "v20.events.data.microsoft.com",
    "self.events.data.microsoft.com",
    "telemetry.microsoft.com",
    "settings-win.data.microsoft.com",
    "diagnostic.data.microsoft.com",
    "watson.telemetry.microsoft.com",
    "oca.telemetry.microsoft.com",
    "sqm.telemetry.microsoft.com",
    "browser.pipe.aria.microsoft.com",
    "mobile.pipe.aria.microsoft.com",
    "statsfe2.ws.microsoft.com"
  ],

  "tasks": [
    { "path": "\\Microsoft\\Windows\\Application Experience\\",
      "name": "ProgramDataUpdater" },
    { "path": "\\Microsoft\\Windows\\Application Experience\\",
      "name": "Microsoft Compatibility Appraiser" },
    { "path": "\\Microsoft\\Windows\\Application Experience\\",
      "name": "StartupAppTask" },
    { "path": "\\Microsoft\\Windows\\Customer Experience Improvement Program\\",
      "name": "Consolidator" },
    { "path": "\\Microsoft\\Windows\\Customer Experience Improvement Program\\",
      "name": "UsbCeip" },
    { "path": "\\Microsoft\\Windows\\Windows Error Reporting\\",
      "name": "QueueReporting" },
    { "path": "\\Microsoft\\Windows\\DiskDiagnostic\\",
      "name": "Microsoft-Windows-DiskDiagnosticDataCollector" }
  ]
}
